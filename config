# ohmypi config
keybind = alt+backspace=text:\x1b\x7f
keybind = shift+enter=text:\n

# Disabled as it breaks # on uk keyboard
macos-option-as-alt = false

keybind = alt+shift+l=new_split:right
keybind = alt+shift+k=new_split:down
keybind = alt+shift+left=resize_split:left,15
keybind = alt+shift+down=resize_split:down,15
keybind = alt+shift+up=resize_split:up,15
keybind = alt+shift+right=resize_split:right,15
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:top
keybind = ctrl+shift+down=goto_split:bottom

font-family = Jetbrains Mono Medium
font-size = 13.5

window-decoration = none
gtk-titlebar = false
background-opacity = 0.90
background-blur-radius = 10
unfocused-split-opacity = 0.95
window-padding-x=2,2
window-padding-y=2,2

cursor-style = block_hollow

macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = #DFEBF5
macos-icon-screen-color = #74B0CF

app-notifications = false

# Main colors
background = #1A1313
foreground = #E0DBC1

# Cursor
cursor-color = #FAF4DE
cursor-text = #1A1313

# Selection
selection-background = #5C3016
selection-foreground = #FAF4DE

# ANSI Color Palette
# Black
palette = 0 = #1A1313
palette = 8 = #4D382F

# Red
palette = 1 = #B34750
palette = 9 = #D94B43

# Green
palette = 2 = #6B997B
palette = 10 = #77D989

# Yellow
palette = 3 = #EBA123
palette = 11 = #FFCA80

# Blue
palette = 4 = #7A97CC
palette = 12 = #61B8F2

# Magenta/Purple
palette = 5 = #9E7ACC
palette = 13 = #CC6A84

# Cyan/Aqua
palette = 6 = #4CD6D9
palette = 14 = #8DCBCC

# White
palette = 7 = #E0DBC1
palette = 15 = #FAF4DE
